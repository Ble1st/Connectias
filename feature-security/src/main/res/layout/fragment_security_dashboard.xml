<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/textSecurityStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/security_dashboard_title"
        android:contentDescription="@string/security_dashboard_description"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollViewThreats"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/buttonRefresh"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textSecurityStatus">

        <TextView
            android:id="@+id/textThreatsDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:background="?attr/colorSurfaceVariant"
            android:textColor="?attr/colorOnSurface" />

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonRefresh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Refresh"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toTopOf="@id/securityToolsSection"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scrollViewThreats" />

    <TextView
        android:id="@+id/securityToolsSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Security Tools"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:paddingBottom="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonRefresh" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonCertificateAnalyzer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Certificate Analyzer"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/securityToolsSection" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonPasswordStrength"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Password Strength"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonCertificateAnalyzer" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonEncryptionTools"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Encryption Tools"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonPasswordStrength" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonFirewallAnalyzer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Firewall Analyzer"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonEncryptionTools" />

</androidx.constraintlayout.widget.ConstraintLayout>

