<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:translateX="54"
        android:translateY="54">
        <!-- Five-pointed star outline (only outer lines) -->
        <!-- Outer points at radius 38, inner points at radius 15 -->
        <!-- Star drawn by alternating: outer point -> inner point -> outer point -->
        <path
            android:name="star_outline"
            android:fillColor="@android:color/transparent"
            android:strokeColor="#00FF00"
            android:strokeWidth="3.5"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M 0,-38 L -12.1,8.8 L -11.7,36.1 L 4.6,14.3 L 30.7,22.3 L 15,0 L 30.7,-22.3 L 4.6,-14.3 L -11.7,-36.1 L -12.1,-8.8 Z" />
        
        <!-- Large C letter inside the star -->
        <!-- C shape: large arc from top-right to bottom-right, open on left side -->
        <path
            android:name="letter_c"
            android:fillColor="@android:color/transparent"
            android:strokeColor="#00FF00"
            android:strokeWidth="7"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M 14,-14 a 18,18 0 1,1 0,28" />
    </group>
</vector>
