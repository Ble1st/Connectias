<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Expressive Typography Styles -->
    <style name="TextAppearance.Connectias.Expressive.Headline" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.Connectias.Expressive.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.Connectias.Expressive.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.15</item>
    </style>
    
    <!-- Expressive Button Styles -->
    <style name="Widget.Connectias.Button.Expressive" parent="Widget.Material3.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:minHeight">56dp</item>
    </style>
    
    <style name="Widget.Connectias.Button.Tonal.Expressive" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:minHeight">56dp</item>
    </style>
    
    <!-- Expressive Card Styles -->
    <!-- Note: Widget.Material3.CardView is not available in Material 1.13.0 for Views -->
    <!-- Using MaterialComponents.CardView as parent instead -->
    <style name="Widget.Connectias.Card.Expressive" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">?attr/colorSurfaceContainer</item>
    </style>
    
    <style name="Widget.Connectias.Card.Expressive.Hero" parent="Widget.Connectias.Card.Expressive">
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">8dp</item>
        <item name="cardBackgroundColor">?attr/colorPrimaryContainer</item>
    </style>
</resources>

